{
    "functions": {
        "api/img.ts": {
            "includeFiles": "fonts/**"
        }
    },
    "rewrites": [
        {
            "source": "/api/img/:dimensions",
            "destination": "/api/img?dimensions=:dimensions"
        },
        {
            "source": "/api/health",
            "destination": "/api/health"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}